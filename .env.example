# Copy to .env and fill in for local docker-compose runs.

# Database
DB_URL=jdbc:postgresql://postgres:5432/teamcoord
DB_USER=teamcoord
DB_PASSWORD=teamcoord

# JWT — MUST be at least 32 bytes long
JWT_SECRET=please-change-this-jwt-secret-32-bytes-min

# Bootstrap admin (created on first start if missing)
BOOTSTRAP_ADMIN_EMAIL=admin@local
BOOTSTRAP_ADMIN_PASSWORD=admin12345

# Mail (optional; leave blank to disable real SMTP)
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=

# Business tuning
BUSINESS_MAX_ACTIVE_TASKS=5
BUSINESS_CRITICAL_BLOCKER_THRESHOLD=2
